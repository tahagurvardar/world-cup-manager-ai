# Server runtime
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/world-cup-manager-ai

# Use a long random value in production
JWT_SECRET=replace_with_a_long_random_secret

# Single frontend origin. Use the deployed Vercel URL in production.
CLIENT_URL=http://localhost:5173

# Optional comma-separated origins for local + production + preview deployments.
# CLIENT_URLS=http://localhost:5173,http://127.0.0.1:5173,https://your-app.vercel.app
